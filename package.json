{
  "name": "spotify-recommender",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"tsx watch src/bootstrap.ts\" \"vite\"",
    "build": "tsc && vite build",
    "start": "node dist/bootstrap.js",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "dev:client": "vite"
  },
  "dependencies": {
    "@pinecone-database/pinecone": "^2.2.2",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.30.10",
    "express": "^4.19.2",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.8",
    "@types/pg": "^8.11.5",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "drizzle-kit": "^0.21.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.9.3",
    "typescript": "^5.4.5",
    "vite": "^5.2.11"
  }
}